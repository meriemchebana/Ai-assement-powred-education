OPENROUTER_API_KEY=sk-or-v1-replace-with-your-key
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DATA_DIR=./data/final_unified
CORS_ORIGINS=http://localhost:27296,http://127.0.0.1:27296

# AraBERT — HuggingFace Inference API for Arabic text embeddings
# Encoder-only model; improves Arabic RAG retrieval (Law subject + Arabic content)
ARABERT_API_KEY=your_huggingface_api_key_here
ARABERT_MODEL=aubmindlab/bert-large-arabertv02

# Supabase — cloud RAG (pgvector). Leave empty to use local FAISS instead.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key
# HF key for non-Arabic embeddings (can reuse ARABERT_API_KEY)
GENERAL_EMBED_API_KEY=your_huggingface_api_key_here
GENERAL_EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
