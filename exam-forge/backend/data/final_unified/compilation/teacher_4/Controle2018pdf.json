      "total_exercise_points": "4",
      "introduction_context": "Soit l'alphabet A = {a,b}, d├Еfinir les expressions r├Еguli├еres pour les langages :",
      "Question": [
        {
          "id": "1",
          "question_text": "Tous les mots non vides contenant un nombre impair de b.",
          "Solution": "a*b(a*ba*b)* a*",
          "level": "Conceptual"
        },
        {
          "id": "2",
          "question_text": "Tous les mots non vides contenant un nombre pair de a.",
          "Solution": "(b*ab*a) (b*ab*a)* b*|bb*",
          "level": "Conceptual"
