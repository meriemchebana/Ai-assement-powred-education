    {
      "id": "Exercice_03",
      "title": "Exercice 03 (04 pts)",
      "total_exercise_points": "4",
      "introduction_context": "",
      "Question": [
        {
          "id": "1",
          "level": "Procedural",
          "question_text": "Ecrire un programme en lex qui supprime une suite d'espaces et les remplace par un seul espace.",
          "solution_lex_code": [
            "%%",
            "( )+    printf(\" \");",
            "%%",
            "int main(int argc, char *argv[])",
            "{",
            "  yyin = fopen(argv[1], \"r\");",
            "  yylex();",
            "  fclose(yyin);",
            "}"
          ]
        },
        {
          "id": "2",
          "level": "Procedural",
          "question_text": "Ecrire un programme en Flex qui compte le nombre de caractères, de mots et de lignes d'un texte en entrée.",
          "solution_lex_code": [
            "%{",
            "int nbm = 0, nbl = 0, nbc = 0;",
            "%}",
            "mot [a-zA-Z]+",
            "%%",
            "{mot}   nbm++; nbc += yyleng;",
            "\\n      nbl++; nbc++;",
            ".       nbc++;",
            "%%",
            "main()",
            "{",
            "  yylex();",
            "  printf(\"Il y a %d mots, %d caracteres et %d lignes.\\n\", nbm, nbc, nbl);",
            "}"
          ]
        }
      ]
    }
