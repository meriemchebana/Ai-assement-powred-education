    {
      "id": "Exercice_01",
      "title": "Exercice 01 (06 pts)",
      "total_exercise_points": "6",
      "introduction_context": "",
      "Question": [
        {
          "id": "1",
          "level": "Procedural",
          "question_text": "Donner une expression régulière qui valide une forme simplifiée des adresses électroniques. Définition simplifiée : une adresse électronique est constituée d'un champ ou plusieurs suivies d'un @ suivi d'un champ ou plusieurs. Un champ est constitué d'un caractère ou plusieurs (lettre, chiffre, -, _).",
          "Solution": "([a-zA-Z0-9]|\\-\\_)+@([a-zA-Z0-9]|\\-\\_)+"
        },
        {
          "id": "2",
          "level": "Factual",
          "question_text": "Un nombre binaire est constitué de 0 et de 1.",
          "sub_questions": [
            {
              "id": "2.A",
              "level": "Procedural",
              "question_text": "Donner une expression régulière qui accepte les nombres binaires contenants au moins deux 0.",
              "Solution": "(0|1)*0(0|1)*0(0|1)*"
            },
            {
              "id": "2.B",
              "level": "Procedural",
              "question_text": "Donner une expression régulière qui accepte les nombres binaires contenants au plus trois 0.",
              "Solution": "1(0|ε)1*(0|ε)1*(0|ε)1* | 01*(0|ε)1*(0|ε)1*"
            }
          ]
        },
        {
          "id": "3",
          "level": "Procedural",
          "question_text": "Donner une expression régulière sur l'alphabet {a, b}, qui accepte tous les mots qui ne contiennent pas le facteur bab.",
          "Solution": "a*(b*((aa)a*)*)*(a|ε)"
        }
      ]
    },
    {
      "id": "Exercice_02",
      "title": "Exercice 02 (10 pts)",
      "total_exercise_points": "10",
      "introduction_context": "Soit G la grammaire suivante :",
      "grammar": [
        "A → da | acB",
        "B → abB | daA | Af"
      ],
      "Question": [
        {
          "id": "1",
          "level": "Metacognitive",
          "question_text": "G est-elle LL(1) ? justifier votre réponse. Sinon la transformer pour qu'elle le soit (grammaire G').",
          "Solution": "Non, il existe une factorisation indirecte dans la règle B → abB | daA | Af dont Premiers(A) ∩ Premiers(B) ≠ ∅.",
          "solution_transformation_steps": [
            "A →da|acB",
            "Substitution de A dans la règle de B :",
            "B → abB | daA | Af",
            "B → abB | daA | (da | acB)f",
            "B → abB | daA | daf | acBf",
            "B → abB | acBf | daA | daf",
            "Factorisation :",
            "B → a(bB | cBf) | da(A | f)",
            "B → aB' | daB''",
            "B' → bB | cBf",
            "B'' → A | f"
          ],
          "solution_grammar_G_prime": [
            "A → da | acB",
            "B → aB' | daB''",
            "B' → bB | cBf",
            "B'' → A | f"
          ]
        },
