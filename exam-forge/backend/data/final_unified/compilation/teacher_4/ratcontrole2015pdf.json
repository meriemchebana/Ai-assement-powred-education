    {
      "id": "Exercice_03",
      "title": "Exercice 03 (08 pts)",
      "total_exercise_points": "8",
      "introduction_context": "On souhaite introduire dans les expressions arithmétiques de MIL-0 deux fonctions standard à deux arguments entiers, MIN(a, b) et MAX(a, b), dont les valeurs sont le minimum (resp. le maximum) de leurs deux arguments. On les modélisera comme deux nouvelles formes d'expressions arithmétiques, au même titre que les constantes, les variables et les expressions binaires.",
      "example_code": [
        "VAR a ; b ; r.",
        "LIRE a ; LIRE b {supposés tous deux positifs};",
        "SI a = b ALORS ECRIRE a",
        "SINON",
        "  TANTQUE MIN(a,b) <> MAX(a-b, b-a) FAIRE",
        "    r := MAX(a-b , b-a) ;",
        "    SI a<b ALORS b := r SINON a := r FINSI",
        "  FINTQ ;",
        "  ECRIRE MIN(a, b)",
        "FINSI."
      ],
      "Question": [
        {
          "id": "1",
          "question_text": "1. (2 pts) Etendre le lexeur et le parseur du cours. Les noms 'MIN' et 'MAX' seront traités comme des mots-clés. Attention ! Une forme comme : 'a * MAX(x, y)+b' s'analyse comme : '((a * MAX(x, y))+b)'.",
          "solution_lex_code": [
            "%%",
            "…",
            "MIN { return(LMin); }",
            "MAX { return(LMax); }",
            "…",
            "%%"
          ],
          "solution_yacc_code": [
            "%token LMin LMax",
            "…",
            "FACTEUR : '(' EXPAR ')' { $$ = $2; }",
            "        | Cte           { $$ = cons_ar_cte($1); }",
            "        | VAR           { $$ = cons_ar_var($1); }",
            "        | LMin '(' EXPAR ',' EXPAR ')' { $$ = cons_min($3, $5); }",
            "        | LMax '(' EXPAR ',' EXPAR ')' { $$ = cons_max($3, $5); }",
            "        ;"
          ],
          "level": "Procedural"
        },
        {
          "id": "2",
          "question_text": "2. (2 pts) Etendre le générateur de code du cours.",
          "Solution": [
            "case min: {",
            "  /* Code calculant arg1(e) → $k   */",
            "  /* Code calculant arg2(e) → $k+1 */",
            "  blt $k, $k+1, etiqv",
            "  move $k, $k+1",
            "  j etiqfin",
            "  etiqv: nop",
            "  etiqfin: nop",
            "  break;",
            "}",
            "case max: {",
            "  /* Code calculant arg1(e) → $k   */",
            "  /* Code calculant arg2(e) → $k+1 */",
            "  bgt $k, $k+1, etiqv",
            "  move $k, $k+1",
            "  j etiqfin",
            "  etiqv: nop",
            "  etiqfin: nop",
            "  break;",
            "}"
          ],
          "level": "Procedural"
        },
        {
          "id": "3",
          "question_text": "3. (2 pts) Sur la base de votre proposition, traduire en assembleur MIPS le programme donné en exemple ci-dessus.",
          "Solution": "Hypothèses sur les adresses des variables : a = 0($30), b = 4($30), r = 8($30)",
          "solution_mips_code": [
            "      j e101              # aller au test de la boucle",
            "",
            "# Corps de la boucle TANTQUE",
            "e106: lw  $8, 0($30)     # a",
            "      lw  $9, 4($30)     # b",
            "      sub $8, $8, $9     # $8 = a-b",
            "      lw  $9, 4($30)     # b",
            "      lw  $10, 0($30)    # a",
            "      sub $9, $9, $10    # $9 = b-a",
            "      blt $8, $9, e102",
            "      j   e103           # sinon $8 contient le max",
            "e102: move $8, $9        # $8 contient max(a-b, b-a)",
            "e103: nop",
            "      sw  $8, 8($30)     # r := max(a-b, b-a)",
            "",
            "# SI a<b ALORS b:=r SINON a:=r FINSI",
            "      lw  $8, 0($30)     # a",
            "      lw  $9, 4($30)     # b",
            "      blt $8, $9, e104",
            "      lw  $8, 8($30)     # r",
            "      sw  $8, 4($30)     # b := r",
            "      j   e105",
            "e104: lw  $8, 8($30)     # r",
            "      sw  $8, 0($30)     # a := r",
            "e105: nop",
            "",
            "# Test de la boucle : MIN(a,b) <> MAX(a-b, b-a)",
            "e101: lw  $8, 0($30)     # a",
            "      lw  $9, 4($30)     # b",
            "      bgt $8, $9, e107   # test inverse pour MIN",
            "      j   e108",
            "e107: move $8, $9",
            "e108: nop                # $8 contient min(a, b)",
            "      lw  $9,  0($30)    # a",
            "      lw  $10, 4($30)    # b",
            "      sub $9,  $9, $10   # a-b",
            "      lw  $10, 4($30)    # b",
            "      lw  $11, 0($30)    # a",
            "      sub $10, $10, $11  # b-a",
            "      blt $9,  $10, e109",
            "      j   e110",
            "e109: move $9, $10",
            "e110: nop                # $9 contient max(a-b, b-a)",
            "      bne $8, $9, e106   # retour au corps si MIN <> MAX"
          ],
          "level": "Procedural"
        },
