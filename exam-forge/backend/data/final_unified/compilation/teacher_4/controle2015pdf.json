    {
      "id": "Exercice_03",
      "title": "Exercice 03 (08 pts)",
      "total_exercise_points": "8",
      "introduction_context": "",
      "parts": [
        {
          "id": "Partie_I",
          "title": "Partie I",
          "introduction_context": "On souhaite introduire une nouvelle expression arithmétique à 3 alternances avec les propriétés suivantes : expr_t :<: expr_inf :=: expr_eg :>: expr_sup. Si la valeur de expr_t est strictement inférieure à 0 alors la valeur de l'expression est celle de expr_inf, sinon si la valeur de expr_t est égale à 0 alors la valeur de l'expression est celle de expr_eg, sinon la valeur de l'expression est celle de expr_sup. Les opérateurs :<: , :=: et :>: ont une associativité de droite à gauche comme les opérateurs ?:, mais avec une priorité moindre.",
          "Question": [
            {
              "id": "1",
              "question_text": "1. (2 pts) Modifier les fichiers Lex et Yacc pour accepter ces opérateurs et pour construire l'arbre correspondant.",
              "solution_lex_code": [
                "……",
                "\":<:\" { yylval.chaine = strcpy((char *) malloc(yyleng+1), yytext); return(TOKEN_OPINF); }",
                "\":=:\" { yylval.chaine = strcpy((char *) malloc(yyleng+1), yytext); return(TOKEN_OPEG); }",
                "\":>:\" { yylval.chaine = strcpy((char *) malloc(yyleng+1), yytext); return(TOKEN_OPSUP); }"
              ],
              "solution_yacc_code": [
                "%token <chaine> TOKEN_VARIABLE TOKEN_OPINF TOKEN_OPEG TOKEN_OPSUP",
                "………",
                "%start EE",
                "%%",
                "EE : M { a = $1; };",
                "M : C TOKEN_OPINF M TOKEN_OPEG M TOKEN_OPSUP { $$ = CreerQuad($1, $3, $5, $7); }",
                "  | C { $$ = $1; };",
                "C : E '?' C ':' C { $$ = CreerTer($1, $3, $5); }",
                "  | E { };"
              ],
              "level": "Procedural"
            },
            {
              "id": "2",
              "question_text": "2. (2 pts) Donner un modèle de code pour cette nouvelle expression.",
              "Solution": [
                "# Code calculant l'expression C → résultat dans $n",
                "li $n+1, 0",
                "blt $n, $n+1, et1",
                "beq $n, $n+1, et2",
                "# Code calculant l'expression M3 (expr_sup) → $n",
                "j et3",
                "et1: # Code calculant l'expression M2 (expr_inf) → $n",
                "j et3",
                "et2: # Code calculant l'expression M1 (expr_eg) → $n",
                "et3: nop"
              ],
              "level": "Procedural"
            }
          ]
        },
        {
          "id": "Partie_II",
          "title": "Partie II",
          "introduction_context": "",
          "Question": [
            {
              "id": "1",
              "question_text": "1. (1 pt) Proposer une fonction récursive (en MNL) permettant de calculer la suite de fibonacci définie de la manière suivante : U0 = 0, U1 = 1, Un = Un-1 + Un-2",
              "Solution": [
                "FONC FIB(n)",
                "{",
                "  SI n < 2",
                "    RETOUR n ;",
                "  SINON",
                "    RETOUR FIB(n-1) + FIB(n-2) ;",
                "}"
              ],
              "level": "Procedural"
            },
            {
              "id": "2",
              "question_text": "2. (1 pt) Construire l'arbre correspondant.",
              "Solution": {
                "type": "AST",
                "description": "Arbre syntaxique de la fonction FIB",
                "tree": {
                  "node": "FONC FIB(n)",
                  "children": [
                    {
                      "node": "SI (n < 2)",
                      "children": [
                        {
                          "branch": "vrai",
                          "node": "RETOUR",
                          "children": [
                            {
                              "node": "n"
                            }
                          ]
                        },
                        {
                          "branch": "faux",
                          "node": "RETOUR",
                          "children": [
                            {
                              "node": "+",
                              "children": [
                                {
                                  "node": "FIB(n-1)"
                                },
                                {
                                  "node": "FIB(n-2)"
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              },
              "level": "Procedural"
            },
            {
              "id": "3",
              "question_text": "3. (2 pts) Ecrire le code MIPS pour cette fonction (selon le principe donné dans le cours).",
              "reference_lex_code": [
                "……",
                "%}",
                "ER_ENTIER -?[0-9]+",
                "ER_VARIABLE [a-zA-Z][0-9a-zA-Z]*",
                "ER_SEPARATEUR [ \\n\\t]",
                "%%",
                "{ER_SEPARATEUR}+ {}",
                "{ER_ENTIER} { yylval.entier = atoi(yytext); return(TOKEN_ENTIER); }",
                "{ER_VARIABLE} { yylval.chaine = strcpy((char *)malloc(yyleng+1), yytext); return(TOKEN_VARIABLE); }",
                "[\\+\\-] { yylval.caractere = yytext[0]; return(TOKEN_PLUS_MOINS); }",
                "[\\*\\/\\%] { yylval.caractere = yytext[0]; return(TOKEN_MULT_DIV); }",
                "[\\(\\)] { return(yytext[0]); }",
                "\"++\"|\"--\" { yylval.caractere = yytext[0]; return(TOKEN_INC_DEC); }",
                "[?:=] { return(yytext[0]); }",
                "<<EOF>> { return(0); }"
              ],
              "reference_mnl_mips": {
                "type": "table",
                "headers": [
                  "MNL",
                  "MIPS"
                ],
                "rows": [
                  [
                    "lire x",
                    "li $2, val\nsyscall\nsw $2, décalage_de_la_variable($30)"
                  ],
                  [
                    "ECRIRE expression",
                    "... code de l'expression résultat → $8\nmove $4, $8\nli $2, 1\nsyscall"
                  ],
                  [
                    "ECRIRE chaine",
                    "la $4, adresse_de_la_chaine\nli $2, 4\nsyscall"
                  ],
                  [
                    "SI expression\n  ALORS alternance_vraie\n  SINON alternance_fausse",
                    "code de l'expression – résultat → $8\nbne $8, $9, etiqv\ncode de l'alternance fausse\nj etiqfin\netiqv: code de l'alternance vraie\n...\netiqfin: nop"
                  ],
                  [
                    "TANTQUE comparaison FAIRE corps FINTQ",
                    "j etiqtest\netiqcorps: code du corps\n...\netiqtest: ... code de l'expression résultat → $8\nbne $8, $0, etiqcorps"
                  ]
                ]
              },
              "reference_mips_syntax_table": {
                "type": "table",
                "headers": [
                  "Syntaxe",
                  "Effet",
                  "Syntaxe",
                  "Effet"
                ],
                "rows": [
                  [
                    "move r1, r2",
                    "r1 ← r2",
                    "lw r1, o(r2)",
                    "r1 ← mémoire[r2+o]"
                  ],
                  [
                    "add r1, r2, o",
                    "r1 ← r2 + o",
                    "sw r1, o(r2)",
                    "mémoire[r2+o] ← r1"
                  ],
                  [
                    "sub r1, r2, o",
                    "r1 ← r2 - o",
                    "slt r1, r2, o",
                    "r1 ← (r2 < o)"
                  ],
                  [
                    "mul r1, r2, o",
                    "r1 ← r2 × o",
                    "sle r1, r2, o",
                    "r1 ← (r2 <= o)"
                  ],
                  [
                    "div r1, r2, o",
                    "r1 ← r2 ÷ o",
                    "seq r1, r2, o",
                    "r1 ← (r2 = o)"
                  ],
                  [
                    "and r1, r2, o",
                    "r1 ← r2 and o",
                    "sne r1, r2, o",
                    "r1 ← (r2 != o)"
                  ],
                  [
                    "or  r1, r2, o",
                    "r1 ← r2 or o",
                    "j o",
                    "pc ← o"
                  ],
                  [
                    "xor r1, r2, o",
                    "r1 ← r2 xor o",
                    "jal o",
                    "ra ← pc+1 et pc ← o"
                  ],
                  [
                    "sll r1, r2, o",
                    "r1 ← r2 << o",
                    "beq r, o, a",
                    "pc ← a si r = o"
                  ],
                  [
                    "srl r1, r2, o",
                    "r1 ← r2 >> o",
                    "bne r, o, a",
                    "pc ← a si r <> o"
                  ],
                  [
                    "li r1, n",
                    "r1 ← n",
                    "syscall",
                    "appel système"
                  ],
                  [
                    "la r1, a",
                    "r1 ← a",
                    "nop",
                    "ne fait rien"
                  ]
                ]
              },
              "reference_syscall_table": {
                "type": "table",
                "headers": [
                  "Nom",
                  "N°",
                  "Effet"
                ],
                "rows": [
                  [
                    "print_int",
                    "1",
                    "imprime l'entier contenu dans a0"
                  ],
                  [
                    "print_string",
                    "4",
                    "imprime la chaîne en a0 jusqu'à '\\000'"
                  ],
                  [
                    "read_int",
                    "5",
                    "lit un entier et le place dans v0"
                  ],
                  [
                    "sbrk",
                    "9",
                    "alloue a0 bytes dans le tas, retourne l'adresse du début dans v0"
                  ],
                  [
                    "exit",
                    "10",
                    "arrêt du programme en cours d'exécution"
                  ]
                ]
              },
              "reference_yacc_code": [
                "%{",
                "…",
                "EXPR_ARBRE a;",
                "%}",
                "%union { EXPR_ARBRE arbre; char *chaine; int entier; char caractere; }",
                "%token <chaine> TOKEN_VARIABLE",
                "%token <entier> TOKEN_ENTIER",
                "%token <caractere> TOKEN_PLUS_MOINS TOKEN_MULT_DIV TOKEN_INC_DEC",
                "%token TOKEN_FIN",
                "%type <arbre> EE E T F G V C",
                "%start EE",
                "%%",
                "EE : C { a = $1; };",
                "C : E '?' C ':' C { $$ = CreerTer($1, $3, $5); }",
                "  | E { };",
                "E : E TOKEN_PLUS_MOINS T { $$ = CreerBin($2, $1, $3); }",
                "  | T { };",
                "T : T TOKEN_MULT_DIV G { $$ = CreerBin($2, $1, $3); }",
                "  | G { };",
                "F : '(' C ')' { $$ = $2; }",
                "  | TOKEN_VARIABLE { $$ = CreerVariable($1); }",
                "  | TOKEN_ENTIER { $$ = CreerConstante($1); };",
                "G : TOKEN_INC_DEC V { $$ = CreerUn($1, $2); }",
                "  | F { };",
                "V : '(' TOKEN_VARIABLE ')' { $$ = CreerVariable($2); }",
                "  | TOKEN_VARIABLE { $$ = CreerVariable($1); };",
                "%%"
              ],
              "solution_mips_code": [
                "FIB:  lw   $8, n",
                "      li   $9, 2",
                "      blt  $8, $9, et1",
                "      sw   $31, -4($sp)",
                "      lw   $8, n",
                "      li   $9, 1",
                "      sub  $8, $8, $9",
                "      sw   $8, -8($sp)",
                "      addi $sp, $sp, -8",
                "      jal  FIB",
                "      move $10, $2",
                "      sw   $31, -4($sp)",
                "      lw   $8, n",
                "      li   $9, 2",
                "      sub  $8, $8, $9",
                "      sw   $8, -8($sp)",
                "      addi $sp, $sp, -8",
                "      jal  FIB",
                "      add  $2, $10, $2",
                "      lw   $31, 4($sp)",
                "      addi $sp, $sp, 8",
                "      jr   $31",
                "      j    et2",
                "et1:  lw   $2, n",
                "      jr   $31",
                "et2:  nop"
              ],
              "level": "Procedural"
            }
