    {
      "id": "Exercice 03",
      "title": "Exercice 03 (09 pts)",
      "total_exercise_points": "9",
      "subsections": [
        {
          "id": "Part 01",
          "title": "Part 01",
          "Question": [
            {
              "id": "1",
              "level": "Procedural",
              "question_text": "1. Ecrire la fonction CréerABS",
              "Solution": [
                "EXPR_ARBRE CreerABS (char *op, EXPR_ARBRE u)",
                "{",
                "  EXPR_ARBRE aux = (EXPR_ARBRE)malloc(sizeof (struct _EXPR_ARBRE));",
                "  aux->type = UNAIRE;",
                "  aux->forme.un.op = (char*)malloc(sizeof(2*char));",
                "  strcpy(aux->forme.un.op, \"||\");",
                "  aux->forme.un.u = u;",
                "  return(aux);",
                "}"
              ]
            }
          ]
        },
        {
          "id": "Part 02",
          "title": "Part 02",
          "Question": [
            {
              "id": "1",
              "level": "Procedural",
              "question_text": "Construire l’arbre correspondant",
              "Solution": {
                "description": "Arbre de Syntaxe Abstraite (AST) pour Fibonacci.",
                "precise_location": "Corrigé Page 4/5",
                "tree_nodes": "SI -- branch 1: == (n, 0) | SI -- branch 2: Ecrire (0) | SI -- branch 3: SI (Sinon Si)",
                "nested_si": "SI (2nd) -- branch 1: == (n, 1) | SI (2nd) -- branch 2: Ecrire (1) | SI (2nd) -- branch 3: ; (Chain)",
                "statement_chain": "; -- branch 1: := (Un2, 0) | ; -- branch 2: ; -- branch 1: := (Un1, 1) | ; -- branch 2: tq (>= (n, 2), StatementBlock) | ; -- branch 3: Ecrire (chaine) | ; -- branch 4: Ecrire (Un1)"
              }
            },
            {
              "id": "2",
              "level": "Procedural",
              "question_text": "donner le code MIPS complet pour ce programme",
              "Solution": [
                ".data",
                "MEM: .space",
                "chaine0: .asciiz \"Donnez la valeur de n\"",
                "chaine1: .asciiz \"Le nombre de Fibonacci de n est:\\n\"",
                ".text",
                "main: la $30, MEM",
                "la $4, chaine0",
                "li $2, 4",
                "syscall #ECRIRE Chaine0",
                "li $2, 5",
                "syscall #lire n",
                "sw $2, 0($30)",
                "lw $8, 0($30)",
                "li $9, 0",
                "beq $8, $9, 100 # SI n == 0",
                "lw $8, 0($30)",
                "li $9, 1",
                "beq $8, $9, 101 # SI n == 1",
                "li $8, 0",
                "sw $8, 12($30) # Un2 := 0",
                "li $8, 1",
                "sw $8, 8($30) # Un1 := 1",
                "j 102",
                "103: lw $8, 8($30)",
                "sw $8, 4($30) # U := Un1",
                "lw $8, 4($30)",
                "lw $9, 12($30)",
                "add $8, $8, $9",
                "sw $8, 8($30) # Un1 := U + Un2",
                "lw $8, 4($30)",
                "sw $8, 12($30) # Un2 := U",
                "lw $8, 0($30)",
                "li $9, 1",
                "sub $8, $8, $9 # n := n-1",
                "sw $8, 0($30)",
                "102: lw $8, 0($30)",
                "li $9, 2",
                "bge $8, $9, 103 # tq(n>=2)",
                "la $4, chaine1",
                "li $2, 4",
                "syscall #ECRIRE Chaine1",
                "lw $4, 8($30) #ECRIRE Un1",
                "li $2, 1",
                "syscall",
                "j 104",
                "101: li $4, 1 #ecrire 1",
                "li $2, 1",
                "syscall",
                "j 105",
                "100: li $4, 0 #ecrire 0",
                "li $2, 1",
                "syscall",
                "104: nop",
                "j 105",
                "105: li $2, 10 #exit",
                "syscall"
              ]
            }
          ]
        }
      ]
    }
