    {
      "id": "Exercice_04",
      "title": "Exercice 04 (04 pts)",
      "total_exercise_points": "4",
      "introduction_context": "Soit Gb la grammaire des expressions booléennes : B → B∨B | B∧B | ¬B | (B) | 0 | 1",
      "Question": [
        {
          "id": "1",
          "question_text": "1. A l'aide d'un exemple concret montrer que cette grammaire est ambigüe.",
          "Solution": "",
          "note": "L'exemple concret n'est pas fourni dans le corrigé du document original.",
          "points": "0.5 pt",
          "level": "Conceptual"
        },
        {
          "id": "2",
          "question_text": "2. Ecrire un programme (non ambigu) en yacc permettant d'analyser et évaluer une expression booléenne.",
          "solution_yacc_code": [
            "%token b",
            "%left '∨'",
            "%left '∧'",
            "%right '¬'",
            "%%",
            "L : B '\\n' { printf(\"résultat=%d\", $1); }",
            "  ;",
            "B : B '∨' B { if ($1 == 0 && $3 == 0) $$ = 0; else $$ = 1; }",
            "  | B '∧' B { $$ = $1 * $3; }",
            "  | '¬' B   { if ($2 == 1) $$ = 0; else $$ = 1; }",
            "  | '(' B ')' { $$ = $2; }",
            "  | '0'     { $$ = 0; }",
            "  | '1'     { $$ = 1; }",
            "  ;",
            "%%",
            "void main()",
            "{",
            "  yyparse();",
            "}"
          ],
          "points": "3.5 pt",
          "level": "Procedural"
        }
      ]
    }
