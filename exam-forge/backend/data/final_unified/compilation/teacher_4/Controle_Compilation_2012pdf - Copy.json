              "lex_file": [
                "%{",
                "%}",
                "ER_ENTIER -?[0-9]+",
                "ER_VARIABLE [a-zA-Z][0-9a-zA-Z]*",
                "ER_SEPARATEUR [ \\n\\t]",
                "%%",
                "{ER_SEPARATEUR}+ { }",
                "{ER_ENTIER} {yylval.entier = atoi(yytext); return(TOKEN_ENTIER);}",
                "{ER_VARIABLE} { yylval.chaine = strcpy((char *)malloc(yyleng+1), yytext); return(TOKEN_VARIABLE);}",
                "[\\+\\-] {yylval.caractere = yytext[0]; return(TOKEN_PLUS_MOINS);}",
                "[\\*\\/\\%] {yylval.caractere = yytext[0]; return(TOKEN_MULT_DIV);}",
                "[\\(\\)] {return(yytext[0]);}",
                "\"++\"|\"--\" {yylval.caractere = yytext[0]; return(TOKEN_INC_DEC);}",
