      {
        "id": "Exercice_01",
        "title": "Exercice 01 (04 pts)",
        "total_exercise_points": "4",
        "introduction_context": "On souhaite écrire un analyseur lexical pour le langage de commandes suivant : – une commande est composée d'un nom de commande, suivi d'une liste optionnelle d'arguments, suivie d'une liste facultative d'options ; – une liste d'arguments est une suite d'arguments ; – une liste d'options est une suite non vide d'options encadrée par [ et ], à l'intérieur de laquelle les options sont séparées par virgule « , » ; – une option est un caractère précédé d'un tiret ; – un argument est un identificateur, de même qu'un nom de commande. Par exemple : macom arg1 arg2 [-a,-b] est une commande, ainsi que macom [-f] et macom .",
        "Question": [
          {
            "id": "1",
            "points": "2",
            "level": "",
            "Question": "1. Donnez une expression régulière étendue représentant les chaînes possibles.",
            "Solution": [
              "[a-zA-Z]+( [a-zA-Z]*(\\ [a-zA-Z]*)(\\[\\-[a-zA-Z](\\ \\-[a-zA-Z])*\\]) ?) ?"
            ]
          },
          {
            "id": "2",
            "points": "2",
            "level": "",
            "Question": "2. Dessinez un automate acceptant le langage décrit par cette expression régulière.",
            "Solution": {
              "description": "Automate fini déterministe (DFA). Transitions : 1--[a-zA-Z]-->2, 2--space-->3, 3--[a-zA-Z]-->3, 3--'['-->4, 4--'-'-->6, 6--[a-zA-Z]-->7, 7--','-->6, 7--']'-->8.",
              "precise_location": "Corrigé Page 3"
            }
          }
        ]
      },
