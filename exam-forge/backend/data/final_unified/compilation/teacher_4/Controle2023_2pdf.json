    {
      "id": "Exercice_02",
      "title": "Exercice 02 (08 pts)",
      "total_exercise_points": "8",
      "introduction_context": "Soit la grammaire G :",
      "grammar": [
        "S → bAb | bBa",
        "A → aS | CB",
        "B → b | BC",
        "C → c | cC"
      ],
      "Question": [
        {
          "id": "1",
          "points": null,
          "question_text": "Montrer que cette grammaire est ambigüe.",
          "Solution": "La grammaire est ambiguë : la chaîne bbcca admet deux dérivations les plus à gauche différentes :",
          "solution_derivations": [
            "S → bBa → bBCa → bbCa → bbcCa → bbcca",
            "S → bBa → bBCa → bBCCa → bbCCa → bbcCa → bbcca"
          ],
          "level": "Conceptual"
        },
        {
          "id": "2",
          "points": null,
          "question_text": "Transformez-la pour qu'elle devienne LL(1) ?",
          "Solution": "La factorisation à gauche des non-terminaux S et C est simple. Le nonterminal B était la source à la fois des problèmes de récursivité à gauche et d'ambiguïté, et les deux problèmes sont résolus en générant un seul b, puis zéro ou plusieurs c (via un nouveau non-terminal D). La nouvelle grammaire sera comme suit 2 :",
          "solution_grammar_final": [
            "S → bT",
            "T → Ab | Ba",
            "A → aS | CB",
            "B → bD",
            "C → cD",
            "D → cD | ε"
          ],
          "level": "Procedural"
        },
        {
          "id": "3",
          "points": null,
          "question_text": "Construire la table d'analyse LL(1) de la nouvelle grammaire.",
