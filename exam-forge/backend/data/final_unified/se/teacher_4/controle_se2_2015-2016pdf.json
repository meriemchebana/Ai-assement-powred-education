    {
      "id": "Exercice_02",
      "title": "Exercice 2",
      "total_exercise_points": null,
      "parts": [
        {
          "id": "Partie_1",
          "points": null,
          "question_text": "Rappelez le concept des sémaphores en mettant en évidence le fonctionnement des primitives P et V.",
          "Solution": null,
          "level": "Conceptual"
        },
        {
          "id": "Partie_2",
          "points": null,
          "introduction_context": "Soit P0 et P1 deux processus parallèles se partageant deux ressources R1 et R2. Les algorithmes de ces deux processus sont écrits comme suit :",
          "pseudocode": {
            "declarations": [
              "vars1, s2 : sémaphore init 1, 1 ;"
            ],
            "processes": [
              {
                "name": "Processus P0",
                "code": [
                  "Répéter",
                  "(1) P(s1) ;",
                  "(2) <utiliser R1> ;",
                  "(3) P(s2) ;",
                  "<utiliser R1 et R2>",
                  "V(s1) ;",
                  "V(s2) ;",
                  "Jusqu'à faux",
                  "Fin."
                ]
              },
              {
                "name": "Processus P1",
                "code": [
                  "Répéter",
                  "(1) P(s2) ;",
                  "(2) <utiliser R2> ;",
                  "(3) P(s1) ;",
                  "<utiliser R1 et R2>",
                  "V(s2) ;",
                  "V(s1) ;",
                  "Jusqu'à faux",
                  "Fin."
                ]
              }
            ]
          },
          "question_text": "A quelle situation anormale peut conduire l'exécution de ces deux processus ?",
          "Solution": null,
          "level": "Conceptual"
        },
        {
          "id": "Partie_3",
          "points": null,
          "question_text": "Donner une solution à ce problème.",
          "Solution": null,
          "level": "Procedural"
        }
      ]
    },
    {
