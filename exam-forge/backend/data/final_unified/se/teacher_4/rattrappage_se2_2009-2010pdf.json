      "title": "Exercice 1 (10 points)",
      "total_exercise_points": "10",
      "parts": [
        {
          "id": "Partie_1",
          "points": null,
          "introduction_context": "On dispose d’une carte électronique à base de microcontrôleurs pour contrôler un ensemble de robots. On vous sollicite pour écrire un pseudo code qui contrôle le déplacement de plusieurs robots sur les chemins suivants :",
          "constraints": [
            "Les robots peuvent partir de A vers C ou de D vers A.",
            "Pour éviter tout risque de collision, il faut s'assurer que chaque segment du chemin (segments AB, BC et DB) est utilisé par un robot au plus."
          ],
          "Question": [
            {
              "id": "1",
              "question_text": "Pour répondre à cette question, complétez le pseudo code suivant afin que les règles ci dessus soient respectées. Dans ce programme, chaque robot est commandé par un processus.",
              "Solution": null,
              "level": "Procedural"
            },
            {
              "id": "2",
              "question_text": "Est-ce que votre solution présente un problème de famine ? interblocage ? Justifiez.",
              "Solution": null,
              "level": "Metacognitive"
            }
          ],
          "diagram": {
            "description": "Graphe de chemins pour les robots. Quatre nœuds : A (en haut à gauche), B (en haut au centre), C (en haut à droite), D (en bas). Les arêtes sont : A—B, B—C, B—D.",
            "nodes": [
              "A",
              "B",
              "C",
              "D"
            ],
            "edges": [
              {
                "from": "A",
                "to": "B",
                "label": "segment AB"
              },
              {
                "from": "B",
                "to": "C",
                "label": "segment BC"
              },
              {
                "from": "D",
                "to": "B",
                "label": "segment DB"
              }
            ],
            "paths": [
              "A → B → C",
              "D → B → A"
            ]
          },
          "pseudocode": {
            "declarations": [
              "void TraverserSegAB ( ) ; // Traverser le segment AB",
              "void TraverserSegBC ( ) ; // Traverser le segment BC",
              "void TraverserSegBD ( ) ; // Traverser le segment BD"
            ],
            "processes": [
              {
                "name": "Processus RobotAC",
                "slots": [
                  "/* 1 */",
                  "TraverserSegAB ( ) ;",
                  "/* 2 */",
                  "TraverserSegBC ( ) ;",
                  "/* 3 */"
                ]
              },
              {
                "name": "Processus RobotDA",
                "slots": [
                  "/* 4 */",
                  "TraverserSegBD ( ) ;",
                  "/* 5 */",
                  "TraverserSegAB ( ) ;",
                  "/* 6 */"
                ]
              }
            ]
          }
        }
      ]
