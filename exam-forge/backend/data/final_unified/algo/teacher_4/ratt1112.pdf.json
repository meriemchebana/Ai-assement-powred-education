    {
      "id": "Exercice_2",
      "title": "Exercice 2 LLCs",
      "total_exercise_points": "10 pts",
      "introduction_context": "On souhaite représenter les polynômes par des listes linéaires chaînées, où chaque terme d'un polynôme est rangé dans un maillon de la liste contenant le degré du terme et le coefficient correspondant.",
      "diagram": {
        "preceding_text": "Exemple : Le polynôme $2x^5 + 3x^4 + \\frac{1}{2}x^2 + 1$ est représentée par la liste suivante :",
        "description": "A horizontal linked list representing a polynomial with nodes [2|5], [3|4], [0.5|2], [1|0].",
        "precise_location": "Page 1 - Right column under example text"
      },
      "Question": [
        {
          "id": "2.1",
          "points": "1",
          "level": "Factual",
          "introduction_context": "On vous demande de :",
          "question_text": "1. Donner les structures de données nécessaires à la représentation des polynômes.",
          "Solution": [
            "Type TTerme = Structure",
            "  Coef : réel ;",
            "  Degre : entier ;",
            "  Suivant : Pointeur(TTerme) ;",
            "Fin ;"
          ],
          "model_evaluation_score": "",
          "model_feedback_comments": ""
        },
        {
          "id": "2.2",
          "points": "1.5",
          "level": "Procedural",
          "question_text": "2. Ecrire la fonction Valeur(P, x) permettant de donner la valeur du polynôme P pour x.\nExemple : Valeur(tete, 1) = 6.5",
          "Solution": [
            "Fonction Valeur( P : Pointeur(TTerme), x : réel) : réel;",
            "Var P1 : Pointeur(TTerme);",
            "    S,C : réel;",
            "Début",
            "    S ← 0;",
            "    P1 ← P;",
            "    Tant que (P1 ≠ Nil) faire",
            "        C ← 1;",
            "        Pour i de 1 à Degre(P1) faire",
            "            C ← C*x;",
            "        Fin Pour;",
            "        S ← S + C * Coef(P1);",
            "        P1 ← Suivant(P1);",
            "    Fin TQ;",
            "    Valeur ← S;",
            "Fin;"
          ],
          "model_evaluation_score": "",
          "model_feedback_comments": ""
        },
        {
          "id": "2.3",
          "points": "2.5",
          "level": "Procedural",
          "question_text": "3. Ecrire la procédure Dériver(P) permettant de calculer la dérivée du polynôme P et le retourner dans P.",
          "Solution": [
            "Procédure Dériver( P : Pointeur(TTerme));",
            "Var P1,PP1 : Pointeur(TTerme);",
            "Début",
            "    PP1 ← Nil;",
            "    P1 ← P;",
            "    Tant que (P1 ≠ Nil) faire",
            "        Si (Degré(P1) ≠ 0) Alors",
            "            Aff_Coef(P1, Coef(P1)*Degré(P1));",
            "            Aff_Degré(P1,Degré(P1)-1);",
            "            PP1 ← P1;",
            "            P1 ← Suivant(P1);",
            "        Sinon",
            "            Si (PP1 = Nil) Alors",
            "                P ← Nil;",
            "            Sinon",
            "                Aff_Adr(PP1,Nil)",
            "            Fin Si;",
            "            Libérer(P1);",
            "            P1 ← Nil;",
            "        Fin Si;",
            "    Fin TQ;",
            "Fin;"
          ],
          "model_evaluation_score": "",
          "model_feedback_comments": ""
        },
        {
          "id": "2.4",
          "points": "2.5",
          "level": "Procedural",
          "question_text": "4. Ecrire la procédure Intégrer(P) permettant de calculer l'intégrale du polynôme P et le retourner dans P.",
          "Solution": [
            "Procédure Intégrer( P : Pointeur(TTerme));",
            "Var P1,PP1 : Pointeur(TTerme) ;",
            "Début",
            "  PP1 ← Nil ;",
            "  P1 ← P ;",
            "  Tant que (P1 ≠ Nil) faire",
            "    Aff_Coef(P1, Coef(P1)/(Degré(P1)+1)) ;",
            "    Aff_Degré(P1,Degré(P1)+1) ;",
            "    PP1 ← P1 ;",
            "    P1 ← Suivant(P1) ;",
            "  Fin TQ ;",
            "  Allouer(P1) ;",
            "  Aff_Coef(P1,1) ;",
            "  Aff_Degré(P1,0) ;",
            "  Aff_Adr(P1,Nil) ;",
            "  Si (PP1 = Nil) Alors",
            "    P ← P1 ;",
            "  Sinon",
            "    Aff_Adr(PP1,P1) ;",
            "  Fin Si ;",
            "Fin ;"
          ],
          "model_evaluation_score": "",
          "model_feedback_comments": ""
        },
        {
          "id": "2.5",
          "points": "2.5",
          "level": "Procedural",
          "question_text": "5. Ecrire la procédure Déviation(P, x) permettant de retourner Vrai si x est un point de déviation du polynôme P et Faux si non.",
          "Solution": [
            "Fonction Déviation( P : Pointeur(TTerme), x : réel) : booléen;",
            "Début",
            "  Si (P=Nil ou Degré(P)< 2) Alors",
            "    Déviation ← Faux",
            "  Sinon",
            "    Dériver(P) ;",
            "    Dériver(P) ;",
            "    Déviation ← (Valeur(P,x) = 0) ;",
            "  Fin Si ;",
            "Fin ;"
          ],
          "model_evaluation_score": "",
          "model_feedback_comments": ""
        }
      ]
    }
  ]
