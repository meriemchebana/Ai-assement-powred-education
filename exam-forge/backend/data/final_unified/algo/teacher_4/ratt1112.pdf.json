      "title": "Exercice 1 Tas",
      "total_exercise_points": "10 pts",
      "introduction_context": "Soit les valeurs des clés suivantes : 38, 5, 2, 17, 10, 3, 16, 22, 11, 33",
      "Question": [
        {
          "id": "1.1",
          "points": "1.5",
          "level": "Procedural",
          "introduction_context": "Soit les valeurs des cl´es suivantes :",
          "question_text": "1. Donner le tas dynamique obtenu après l'insertion de ces clés dans l'ordre.",
          "Solution": {
            "description": "A max-heap represented as a binary tree with 10 nodes. Root node: 38. Level 2: 33, 16. Level 3: 17, 22, 3, 2. Level 4: 5, 11, 10.",
            "precise_location": "Page 2 - Upper left column"
          },
          "model_evaluation_score": "",
          "model_feedback_comments": ""
        },
        {
          "id": "1.2",
          "points": "1.5",
          "level": "Procedural",
          "question_text": "2. Donner le tas statique correspondant.",
          "Solution": {
            "description": "A horizontal array representation: [1]:38, [2]:33, [3]:16, [4]:17, [5]:22, [6]:3, [7]:2, [8]:5, [9]:11, [10]:10.",
            "precise_location": "Page 2 - Middle left column"
          },
          "model_evaluation_score": "",
          "model_feedback_comments": ""
        },
        {
          "id": "1.3",
          "points": "1",
          "level": "Factual",
          "question_text": "3. Donner la déclaration des structures de données permettant de représenter en mémoire le tas statique précédent.",
          "Solution": [
            "Var Tas : Tableau[1..NMax] de entier",
            "N : entier ; // nombre d’éléments dans le tas, initialisé à 0"
          ],
          "model_evaluation_score": "",
          "model_feedback_comments": ""
        },
        {
          "id": "1.4",
          "points": "2.5",
          "level": "Procedural",
          "question_text": "4. Ecrire la procédure Enfiler(x) permettant d'ajouter au tas statique la valeur x.",
          "Solution": [
            "Procédure Enfiler( x : entier ;);",
            "Var P,Pere : entier ;",
            "Début",
            "    Si (N=NMax) Alors",
            "        Ecrire(’le tas est plein’)",
            "    Sinon",
            "        N ← N+1;",
            "        Tas[N] ← x;",
            "        P ← N;",
            "        Pere ← N div 2;",
            "        Tant que ((P > 1) et (Tas[Pere] < Tas[P])) faire",
            "            x ← Tas[Pere];",
            "            Tas[Pere] ← Tas[P];",
            "            Tas[P] ← x;",
            "            P ← Pere;",
            "            Pere ← P div 2;",
            "        Fin TQ;",
            "    Fin Si;",
            "Fin;"
          ],
          "model_evaluation_score": "",
          "model_feedback_comments": ""
        },
        {
          "id": "1.5",
          "points": "2.5",
          "level": "Procedural",
          "question_text": "5. Ecrire la fonction Défiler permettant de défiler une clé du tas statique.",
          "Solution": [
            "Fonction Defiler() : entier;",
            "Var P,Fils1,Fils2,PMax,x : entier ;",
            "Début",
            "  Si (N=0) Alors",
            "    Ecrire(’le tas est vide’)",
            "  Sinon",
            "    Defiler ← Tas[1] ;",
            "    Tas[1] ← Tas[N] ;",
            "    N ← N-1 ;",
            "    P ← 1;",
            "    Fils1 ← 2 ;",
            "    Fils2 ← 3 ;",
            "    Tant que (((Fils1 ≤ N) et (Tas[P] < Tas[Fils1]))",
            "    ou ((Fils2 ≤ N) et (Tas[P] < Tas[Fils2]))) faire",
            "      Si (Fils2 > N) Alors",
            "        PMax ← Fils1",
            "      Sinon",
            "        Si (Tas[Fils1] > Tas[Fils2]) Alors",
            "          PMax ← Fils1",
            "        Sinon",
            "          PMax ← Fils2",
            "        Fin Si;",
            "      Fin Si;",
            "      x ← Tas[P] ;",
            "      Tas[P] ← Tas[PMax] ;",
            "      Tas[PMax] ← x ;",
            "      P ← PMax ;",
            "      Fils1 ← P * 2 ;",
            "      Fils2 ← P * 2 + 1 ;",
            "    Fin TQ;",
            "  Fin Si;",
            "Fin;"
          ],
          "model_evaluation_score": "",
          "model_feedback_comments": ""
        },
        {
          "id": "1.6",
          "points": "1",
          "level": "Procedural",
          "question_text": "6. Donner le tas statique de la question 2, après les appels suivants : Enfiler(4) ; Enfiler(14) ; Défiler ; Enfiler(1) ; Défiler ;",
